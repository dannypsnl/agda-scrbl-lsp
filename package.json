{
  "name": "agda-scrbl",
  "publisher": "dannypsnl",
  "displayName": "Agda in Scribble (.lagda.scrbl)",
  "description": "Interactive Agda development directly on literate .lagda.scrbl cards",
  "version": "0.0.1",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/dannypsnl/agda-scrbl-lsp.git" },
  "bugs": { "url": "https://github.com/dannypsnl/agda-scrbl-lsp/issues" },
  "homepage": "https://github.com/dannypsnl/agda-scrbl-lsp#readme",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["workspaceContains:**/*.lagda.scrbl"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lagda-scrbl",
        "aliases": ["Literate Agda (Scribble)"],
        "filenamePatterns": ["*.lagda.scrbl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      { "command": "agda-scrbl.caseSplit", "title": "Agda (scrbl): Case Split" },
      { "command": "agda-scrbl.give", "title": "Agda (scrbl): Give" },
      { "command": "agda-scrbl.refine", "title": "Agda (scrbl): Refine" },
      { "command": "agda-scrbl.goalType", "title": "Agda (scrbl): Goal Type & Context" },
      { "command": "agda-scrbl.insertSymbol", "title": "Agda (scrbl): Insert Unicode Symbol" },
      { "command": "agda-scrbl.load", "title": "Agda (scrbl): Load / Reload" },
      { "command": "agda-scrbl.restart", "title": "Agda (scrbl): Restart Agda" }
    ],
    "keybindings": [
      { "command": "agda-scrbl.caseSplit", "key": "ctrl+c ctrl+c", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/" },
      { "command": "agda-scrbl.give", "key": "ctrl+c ctrl+space", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/" },
      { "command": "agda-scrbl.refine", "key": "ctrl+c ctrl+r", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/" },
      { "command": "agda-scrbl.load", "key": "ctrl+c ctrl+l", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/" },
      { "command": "agda-scrbl.restart", "key": "ctrl+c ctrl+x ctrl+r", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/" },
      { "command": "agda-scrbl.insertSymbol", "key": "\\", "when": "editorTextFocus && resourceFilename =~ /\\.lagda\\.scrbl$/ && !suggestWidgetVisible && !inQuickOpen" }
    ],
    "configuration": {
      "title": "Agda (scrbl)",
      "properties": {
        "agda-scrbl.loadTimeout": {
          "type": "number",
          "default": 120,
          "minimum": 1,
          "markdownDescription": "Seconds to wait for `agda` to respond to a load before giving up and reporting that Agda is not responding. Raise this if cold-compiling large libraries (TypeTopology, cubical) legitimately takes longer. Reload the window to apply a change."
        },
        "agda-scrbl.unicodeInput.userSymbols": {
          "type": "array",
          "default": [],
          "description": "User-defined unicode symbols. Each entry: { name, glyph, aliases? }. User entries override built-ins with the same name and are searchable by name and aliases in both the inline \\-completion and the Insert Symbol picker.",
          "items": {
            "type": "object",
            "required": ["name", "glyph"],
            "properties": {
              "name": { "type": "string", "description": "Canonical name shown in the picker (typeable as \\name)." },
              "glyph": { "type": "string", "description": "The unicode character(s) inserted." },
              "aliases": { "type": "array", "items": { "type": "string" }, "description": "Alternate names searched by the picker and completion." }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "bun run test.ts",
    "test:unicode": "bun run test-unicode.ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
